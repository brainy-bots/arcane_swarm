FROM rust:1.85-bookworm AS builder
WORKDIR /app
COPY crates/arcane-benchmark-swarm ./crates/arcane-benchmark-swarm
WORKDIR /app/crates/arcane-benchmark-swarm
RUN cargo build --bin arcane-swarm --release

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/crates/arcane-benchmark-swarm/target/release/arcane-swarm /usr/local/bin/arcane-swarm
ENTRYPOINT ["arcane-swarm"]
